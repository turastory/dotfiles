# Migrated from iTerm2 3.6.10 default profile

# Shell and working directory
command = /bin/zsh
working-directory = inherit
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Font
font-family = Monaspace Argon
font-size = 16
font-synthetic-style = bold,italic,bold-italic

# Terminal behavior
term = xterm-256color
mouse-reporting = true
scroll-to-bottom = keystroke,no-output
scrollback-limit = 1000000

# Window sizing and appearance
window-width = 80
window-height = 25
window-step-resize = true
background-opacity = 0.9
background-opacity-cells = false
background-blur = true
window-padding-x = 2
window-padding-y = 2
window-theme = auto
window-colorspace = srgb
macos-titlebar-style = transparent
macos-window-shadow = true

# Colors
background = #26292c
foreground = #cfd2d0
bold-color = #cfd2d0
cursor-color = #c5c8c6
cursor-text = #1d1f21
selection-background = #373b41
selection-foreground = #bfd1c5
minimum-contrast = 1

palette = 0=#333333
palette = 1=#cc6666
palette = 2=#b5bd68
palette = 3=#f0c674
palette = 4=#577f9d
palette = 5=#b294bb
palette = 6=#8abeb7
palette = 7=#ffffff
palette = 8=#808080
palette = 9=#cc6666
palette = 10=#b5bd68
palette = 11=#f0c674
palette = 12=#577e9d
palette = 13=#b294bb
palette = 14=#8abeb7
palette = 15=#ffffff

# Keyboard and mouse behavior
macos-option-as-alt = true
copy-on-select = true
right-click-action = context-menu
confirm-close-surface = false
bell-features = no-system,no-audio,attention,title,no-border

# iTerm2 custom key mappings
keybind = alt+arrow_left=esc:b
keybind = alt+arrow_right=esc:f
keybind = alt+backspace=text:\x1b\x7f
keybind = super+arrow_left=text:\x01
keybind = super+arrow_right=text:\x05
keybind = super+backspace=text:\x15
keybind = delete=text:\x04
keybind = alt+delete=esc:d

# Existing Ghostty macOS app defaults made explicit
click-repeat-interval = 500
auto-update-channel = stable

# Not directly portable from iTerm2:
# - Status bar components: job, battery, CPU, memory, clock
# - Dynamic profile clone tagged "Dynamic" uses font size 14
# - iTerm2 blur radius 11.655; Ghostty 1.3.1 exposes blur as a boolean
# - iTerm2 scrollback is 1000 lines; Ghostty uses a byte limit, set above
# - iTerm2 "Recycle" custom directory maps closest to Ghostty inherit behavior
